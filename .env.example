# Required
DATABASE_URL=postgres://admin:YOUR_PASSWORD@localhost:5433/email_waitlist?sslmode=disable
ADMIN_KEY=your-secret-admin-key-here

# Optional
PORT=8090
RATE_LIMIT=30

# Email confirmations (optional — disabled if RESEND_API_KEY is not set)
RESEND_API_KEY=re_your_resend_api_key
DEFAULT_FROM_EMAIL=Waitlist <waitlist@yourdomain.com>
